# Create .dockerignore
# Ye unnecessary files container me copy hone se rokta hai.

# Ignore Python cache
__pycache__/
*.pyc

# Ignore virtual environment
venv/
env/

# Ignore local uploads
uploads/

# Ignore vector db
vectorstores/

# Ignore git files (isse poora Git history folder Docker image me copy nahi hoga.)
.git/

# Ignore notebook files
*.ipynb

# Ignore OS files
.DS_Store

# Ignore .en file (Ignore secrets)
.env

# Ignore unnecessary files & folders
requirements_old.txt

.vscode/
timepass/
figures/